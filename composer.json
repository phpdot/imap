{
    "name": "phpdot/imap",
    "description": "Enterprise-grade IMAP4rev1/IMAP4rev2 protocol library for PHP",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["imap", "imap4rev2", "rfc9051", "rfc3501", "email", "protocol"],
    "require": {
        "php": ">=8.2",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Mail\\IMAP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Mail\\IMAP\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
